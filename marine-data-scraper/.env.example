# Copy this to .env and customise

# HTTP request settings
REQUEST_DELAY=2.0        # seconds between requests (be polite)
REQUEST_TIMEOUT=30
MAX_RETRIES=3
MAX_CONCURRENT=3

# Optional: proxy rotation (leave blank if not using)
# HTTP_PROXY=http://user:pass@proxy:port
# HTTPS_PROXY=http://user:pass@proxy:port

# Optional: override default DB path
# DB_PATH=/path/to/custom/marine.db
